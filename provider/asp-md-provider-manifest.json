{
  "schemaId": "agent.semantic-protocols.hook.provider-manifest",
  "schemaVersion": "1",
  "protocolId": "agent.semantic-protocols.hook",
  "protocolVersion": "1",
  "manifestId": "agent.semantic-protocols.providers.md.orgize",
  "manifestVersion": "v1",
  "languageId": "md",
  "providerId": "orgize",
  "namespace": "agent.semantic-protocols.languages.md.orgize",
  "binary": "asp",
  "execution": "embedded",
  "source": {
    "defaultExtensions": [
      ".md",
      ".markdown"
    ],
    "defaultConfigFiles": [],
    "defaultSourceRoots": [
      "docs"
    ],
    "defaultIgnoredPathPrefixes": [
      "target"
    ],
    "defaultProjectMarkers": [],
    "defaultDependencyMarkers": []
  },
  "policy": {
    "directSourceRead": "block",
    "bulkSourceDump": "block",
    "rawSourceSearch": "block",
    "agentSearchJson": "block"
  },
  "routes": {
    "prime": {
      "argv": [
        "asp",
        "md",
        "search",
        "prime",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "owner": {
      "argv": [
        "asp",
        "md",
        "query",
        "--selector",
        "{path}",
        "--view",
        "metadata",
        "{projectRoot}"
      ]
    },
    "fzf": {
      "argv": [
        "asp",
        "md",
        "query",
        "--term",
        "{query}",
        "--view",
        "metadata",
        "{projectRoot}"
      ]
    },
    "query": {
      "argv": [
        "asp",
        "md",
        "query",
        "{termArgs}",
        "--view",
        "metadata",
        "{projectRoot}"
      ]
    },
    "ingest": {
      "argv": [
        "asp",
        "md",
        "search",
        "prime",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ],
      "stdinMode": "pipe-candidates"
    },
    "checkChanged": {
      "argv": [
        "asp",
        "md",
        "search",
        "prime",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "guide": {
      "argv": [
        "asp",
        "md",
        "guide",
        "{projectRoot}"
      ]
    }
  }
}
